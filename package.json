{
  "name": "opencode-control-surface",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production BUILD_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo dev) BUILD_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo dev) BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) bun run server/index.ts",
    "lint": "eslint .",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "check": "NODE_OPTIONS=--max-old-space-size=4096 bun run typecheck && NODE_OPTIONS=--max-old-space-size=4096 bun run build",
    "test:e2e": "playwright test",
    "build:binary": "bun run build && BUILD_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo dev) BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) bun build --compile --target=bun-linux-x64 --outfile=dist/tib-builder server/main.ts",
    "build:docker": "docker build -t tib-builder:latest .",
    "agent-sessions:audit": "bun scripts/agent-session-audit.ts --include-internal",
    "agent-sessions:snapshot-opencode": "bun scripts/snapshot-opencode-legacy-sessions.ts"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "docx": "^9.7.1",
    "hono": "^4.12.21",
    "lucide-react": "^0.469.0",
    "pdfkit": "^0.19.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "routerlicious": "^0.0.1",
    "wouter": "^3.9.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.0.0",
    "eslint": "^9.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "private": true
}
