# Cloud Tier Environment Template
# Copy to customer.env and fill in values before running provision.sh

# --- Licensing ---
# License key for the Cloud Tier instance (Solo tier by default)
LICENSE_PATH=/opt/opencode-control-surface/data/license.key

# --- Operator Auth ---
# Token used to authenticate builder/admin API calls
OPERATOR_TOKEN=changeme_replace_with_random_string

# --- Database ---
# SQLite path for the dashboard database
DASHBOARD_DB_PATH=/opt/opencode-control-surface/data/dashboard.db

# --- LiteLLM ---
# URL of the LiteLLM proxy for model routing
LITELLM_URL=http://127.0.0.1:4000

# --- Telemetry (opt-in) ---
# Set to 1 to enable anonymous telemetry
TELEMETRY_OPT_IN=0

# --- Cloudflared Tunnel ---
# Token from Cloudflare Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=

# --- Hostname ---
# Public hostname served via Cloudflare Tunnel
PUBLIC_HOSTNAME=
